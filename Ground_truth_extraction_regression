# HTML PARSING
# =============================================================================

SECTION_KEYS = {
    'LV':          ['αριστερή κοιλία', 'αριστερη κοιλια'],
    'TV':          ['τριγλώχινα', 'τριγλωχινα', 'tricuspid'],
    'RV':          ['δεξιά κοιλία', 'δεξια κοιλια', 'right ventricle'],
    'PA':          ['πνευμονική', 'πνευμονικη', 'pulmonary'],
    'CONCLUSIONS': ['συμπεράσματα', 'συμπερασματα', 'conclusions'],
}

def parse_sections(html: str) -> dict:
    if not BS4_AVAILABLE:
        return _parse_sections_regex(html)

    soup = BeautifulSoup(html, 'html.parser')
    sections = {}

    for p_tag in soup.find_all('p'):
        header_span = p_tag.find('span', style=lambda s: s and 'underline' in s)
        if not header_span:
            continue

        raw_header = header_span.get_text(strip=True)
        raw_header = re.sub(r'[.:]+\s*$', '', raw_header).strip().lower()

        section_key = None
        for key, aliases in SECTION_KEYS.items():
            if any(alias in raw_header or raw_header in alias for alias in aliases):
                section_key = key
                break
        
        if not section_key:
            continue 

        header_span.extract()
        section_text = p_tag.get_text(separator=' ', strip=True)

        if section_key in sections:
            sections[section_key] += ' ' + section_text
        else:
            sections[section_key] = section_text

    return sections

def _parse_sections_regex(html: str) -> dict:
    sections = {}
    pattern = r'<span[^>]*text-decoration:\s*underline[^>]*>(.*?)</span>(.*?)</p>'
    for m in re.finditer(pattern, html, re.DOTALL | re.IGNORECASE):
        raw_header = re.sub(r'<[^>]+>', '', m.group(1)).strip()
        raw_header = re.sub(r'[.:]+\s*$', '', raw_header).lower()
        section_text = re.sub(r'<[^>]+>', ' ', m.group(2)).strip()

        for key, aliases in SECTION_KEYS.items():
            if any(alias in raw_header or raw_header in alias for alias in aliases):
                if key in sections:
                    sections[key] += ' ' + section_text
                else:
                    sections[key] = section_text
                break
    return sections

def get_sec(sections: dict, key: str) -> str:
    return sections.get(key, '')


# =============================================================================
# EXTRACTORS (EF & RVSP)
# =============================================================================

EF_PATTERN = re.compile(
    r'(?:'
    r'[eEεΕ]?[fFφΦ]|'
    r'κ\.?\s*ε\.?|'
    r'κλ[άα]σμ[αα]?\s+εξ[ώω]θησ[ηι][σς]?'
    r')'
    r'\s*(?:[:=]|εκτιμ[άα]ται\s+στ[οη]v?)?\s*'
    r'([<>\~]?)\s*'
    r'(\d{2})'
    r'(?:\s*(?:-|έως|εως)\s*(\d{2}))?'
    r'\s*[%]?',
    re.IGNORECASE
)

# Το νέο, "αλεξίσφαιρο" Regex για την πίεση
RVSP_PATTERN = re.compile(
    r'(?:'
    r'rvsp|r\.?v\.?s\.?p\.?|'
    r'δκπ|'
    r'spap|s\.?p\.?a\.?p\.?|'
    r'paps|p\.?a\.?p\.?s\.?|'
    r'(?:εκτιμ[ώω]μεν[ηη]\s+)?(?:συστολικ[ήη]\s+)?πίεσ[ηη]\s+(?:της\s+)?(?:δεξ[ιί][αά][σς]?\s+)?κοιλ[ιί][αα][σς]?(?:\s*\([^\)]+\))?|'
    r'(?:systolic\s+)?right\s+ventricular\s+(?:systolic\s+)?pressure(?:\s*\([^\)]+\))?|'
    r'(?:εκτιμ[ώω]μεν[ηη]\s+)?(?:μέση\s+|συστολικ[ήη]\s+)?πνευμονικ[ήη](?:\s+πίεσ[ηη])?(?:\s*\([^\)]+\))?|'
    r'(?:συστολικ[ήη]\s+)?πίεσ[ηη]\s+(?:της\s+)?πνευμονικ[ήη][σς](?:\s+αρτηρία[σς])?(?:\s*\([^\)]+\))?'
    r')'
    r'\s*(?:[:=≈~-]|(?:εκτιμ[άα]ται|υπολογ[ιί]ζεται|είναι|αν[έε]ρχεται)(?:\s+(?:σε|στα|περ[ιί]))?)?\s*'
    r'([<>\~]?)\s*'
    r'\(?\s*(\d{2,3})\s*\)?'
    r'(?:\s*(?:-|έως|εως)\s*(\d{2,3}))?'
    r'\s*(?:mm\s*hg|mmhg)?',
    re.IGNORECASE
)

def _extract_numeric(pattern: re.Pattern, text: str) -> dict:
    """
    Επιστρέφει dict με:
      - exact_value:    float ή None (ακριβής τιμή, μόνο αν δεν είναι range/modifier)
      - modifier_value: str ή None  (π.χ. ">55", "<60", "~50")
      - range_value:    str ή None  (π.χ. "55-60")
      - status:         'exact' | 'modifier' | 'range' | 'not_found'
    """
    result = {'exact_value': None, 'modifier_value': None, 'range_value': None, 'status': 'not_found'}

    if not text.strip():
        return result

    match = pattern.search(text)
    if not match:
        return result

    modifier = match.group(1)
    val1     = int(match.group(2))
    val2     = match.group(3)

    if val2:
        result['range_value'] = f"{val1}-{val2}"
        result['status'] = 'range'
    elif modifier in ('<', '>', '~'):
        result['modifier_value'] = f"{modifier}{val1}"
        result['status'] = 'modifier'
    else:
        result['exact_value'] = float(val1)
        result['status'] = 'exact'

    return result

def extract_exact_ef(sections: dict) -> dict:
    text = get_sec(sections, 'LV') + ' ' + get_sec(sections, 'CONCLUSIONS')
    return _extract_numeric(EF_PATTERN, text)

def extract_exact_rvsp(sections: dict) -> dict:
    text = (get_sec(sections, 'TV') + ' '
            + get_sec(sections, 'RV') + ' '
            + get_sec(sections, 'PA') + ' '
            + get_sec(sections, 'CONCLUSIONS'))
    return _extract_numeric(RVSP_PATTERN, text)

def extract_labels_from_html(html: str) -> dict:
    sections = parse_sections(html)
    ef   = extract_exact_ef(sections)
    rvsp = extract_exact_rvsp(sections)
    return {
        'ef_exact':    ef['exact_value'],
        'ef_modifier': ef['modifier_value'],
        'ef_range':    ef['range_value'],
        'ef_status':   ef['status'],
        'rvsp_exact':    rvsp['exact_value'],
        'rvsp_modifier': rvsp['modifier_value'],
        'rvsp_range':    rvsp['range_value'],
        'rvsp_status':   rvsp['status'],
    }


# =============================================================================
# BATCH PROCESSING LOGIC
# =============================================================================

def run_batch():
    exclusion_ids = load_exclusion_list(EXCLUSION_LIST)
    chm_entries = find_all_chm_files(DATASET_DIR, exclusion_ids)

    if not chm_entries:
        return

    if MAX_FILES:
        chm_entries = chm_entries[:MAX_FILES]

    total = len(chm_entries)
    logger.info(f"Ξεκινά το processing για τις υπόλοιπες {total} εξετάσεις...")

    results, skipped, failed = [], [], []
    
    found_counts = {'ef': 0, 'rvsp': 0}
    skip_counts = {
        'ef':   {'not_found': 0, 'range': 0, 'modifier': 0},
        'rvsp': {'not_found': 0, 'range': 0, 'modifier': 0},
    }

    for i, entry in enumerate(chm_entries):
        exam_id  = entry["exam_id"]
        chm_path = entry["chm_path"]

        if i % 50 == 0 and i > 0:
            logger.info(f"  Επεξεργασία... [{i}/{total}]")

        html = extract_report_html(chm_path)
        if not html:
            logger.warning(f"  ✗ {exam_id}: αποτυχία extraction")
            failed.append({'exam_id': exam_id, 'chm_path': chm_path})
            continue

        labels = extract_labels_from_html(html)

        # Καταγραφή στατιστικών για EF
        if labels['ef_status'] == 'exact':
            found_counts['ef'] += 1
        else:
            skip_counts['ef'][labels['ef_status']] += 1
            
        # Καταγραφή στατιστικών για RVSP
        if labels['rvsp_status'] == 'exact':
            found_counts['rvsp'] += 1
        else:
            skip_counts['rvsp'][labels['rvsp_status']] += 1

        # Αποθήκευση στο κύριο CSV — ΟΛΕΣ οι τιμές καταγράφονται
        # Αν δεν υπάρχει τιμή (not_found), ο exam_id μπαίνει αλλά οι στήλες μένουν κενές
        results.append({
            'exam_id':       exam_id,
            'ef_exact':      labels['ef_exact'],
            'ef_modifier':   labels['ef_modifier'],
            'ef_range':      labels['ef_range'],
            'rvsp_exact':    labels['rvsp_exact'],
            'rvsp_modifier': labels['rvsp_modifier'],
            'rvsp_range':    labels['rvsp_range'],
        })

        # Αν λείπει ΑΚΡΙΒΗΣ τιμή σε ΕΣΤΩ ΚΑΙ ΕΝΑ, καταγραφή λόγου
        if labels['ef_status'] != 'exact' or labels['rvsp_status'] != 'exact':
            skipped.append({
                'exam_id':          exam_id,
                'ef_status':        labels['ef_status'],
                'rvsp_status':      labels['rvsp_status'],
            })

    # --- Αποθήκευση αποτελεσμάτων (Main CSV) ---
    fieldnames = ['exam_id', 'ef_exact', 'ef_modifier', 'ef_range',
                  'rvsp_exact', 'rvsp_modifier', 'rvsp_range']
    with open(OUTPUT_CSV, 'w', newline='', encoding='utf-8') as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(results)

    # --- Αποθήκευση παραλειφθέντων (Skipped CSV) ---
    skipped_csv = OUTPUT_CSV.replace('.csv', '_skipped.csv')
    with open(skipped_csv, 'w', newline='', encoding='utf-8') as f:
        writer = csv.DictWriter(f, fieldnames=['exam_id', 'ef_status', 'rvsp_status'])
        writer.writeheader()
        writer.writerows(skipped)

    # --- Στατιστικά για Terminal ---
    total_processed = total - len(failed)

    logger.info(f"\n{'='*60}")
    logger.info(f"ΣΥΝΟΛΙΚΗ ΑΝΑΦΟΡΑ")
    logger.info(f"{'='*60}")
    logger.info(f"  Εξετάσεις προς επεξεργασία : {total}")
    logger.info(f"  Extraction αποτυχίες       : {len(failed)}")
    logger.info(f"  Επιτυχώς επεξεργάστηκαν    : {total_processed}")

    ef_found = found_counts['ef']
    ef_skipped = total_processed - ef_found
    ef_pct = (ef_found / total_processed * 100) if total_processed > 0 else 0

    logger.info(f"\n--- Ανάλυση EF (Κλάσμα Εξώθησης) ---")
    logger.info(f"  ✓ Κρατήθηκαν (ακριβής) : {ef_found}  ({ef_pct:.1f}%)")
    logger.info(f"  ✗ Παραλείφθηκαν        : {ef_skipped}  ({100-ef_pct:.1f}%)")

    rvsp_found = found_counts['rvsp']
    rvsp_skipped = total_processed - rvsp_found
    rvsp_pct = (rvsp_found / total_processed * 100) if total_processed > 0 else 0

    logger.info(f"\n--- Ανάλυση RVSP (Πίεση Δεξιάς Κοιλίας) ---")
    logger.info(f"  ✓ Κρατήθηκαν (ακριβής) : {rvsp_found}  ({rvsp_pct:.1f}%)")
    logger.info(f"  ✗ Παραλείφθηκαν        : {rvsp_skipped}  ({100-rvsp_pct:.1f}%)")

    logger.info(f"\n{'='*60}")
    logger.info(f"Output CSV     : {OUTPUT_CSV}")
    logger.info(f"Skipped CSV    : {skipped_csv}")

    if failed:
        failed_log = OUTPUT_CSV.replace('.csv', '_failed.csv')
        with open(failed_log, 'w', newline='', encoding='utf-8') as f:
            writer = csv.DictWriter(f, fieldnames=['exam_id', 'chm_path'])
            writer.writeheader()
            writer.writerows(failed)
        logger.info(f"Failed CSV     : {failed_log}")

    # --- Δημιουργία Excel Στατιστικών (ΝΕΟ) ---
    df_general = pd.DataFrame([{
        "Συνολικές Εξετάσεις (Μετά την Exclusion List)": total,
        "Αποτυχίες Ανάγνωσης (Failed)": len(failed),
        "Επιτυχώς Επεξεργάστηκαν": total_processed
    }])

    df_metrics = pd.DataFrame([
        {
            "Μεταβλητή": "EF (Κλάσμα Εξώθησης)",
            "Βρέθηκε Ακριβής Τιμή": ef_found,
            "Ποσοστό Εύρεσης (%)": round(ef_pct, 1),
            "Παραλείφθηκε (Skipped)": ef_skipped,
            "Ποσοστό Παράλειψης (%)": round(100 - ef_pct, 1),
            "Αιτία: Δεν βρέθηκε πουθενά": skip_counts['ef']['not_found'],
            "Αιτία: Ήταν εύρος (π.χ. 55-60)": skip_counts['ef']['range'],
            "Αιτία: Είχε σύμβολα (π.χ. >55)": skip_counts['ef']['modifier'],
        },
        {
            "Μεταβλητή": "RVSP / sPAP",
            "Βρέθηκε Ακριβής Τιμή": rvsp_found,
            "Ποσοστό Εύρεσης (%)": round(rvsp_pct, 1),
            "Παραλείφθηκε (Skipped)": rvsp_skipped,
            "Ποσοστό Παράλειψης (%)": round(100 - rvsp_pct, 1),
            "Αιτία: Δεν βρέθηκε πουθενά": skip_counts['rvsp']['not_found'],
            "Αιτία: Ήταν εύρος (π.χ. 30-35)": skip_counts['rvsp']['range'],
            "Αιτία: Είχε σύμβολα (π.χ. <35)": skip_counts['rvsp']['modifier'],
        }
    ])

    try:
        with pd.ExcelWriter(OUTPUT_EXCEL_STATS, engine='openpyxl') as writer:
            df_general.to_excel(writer, sheet_name='Γενικά_Στοιχεία', index=False)
            df_metrics.to_excel(writer, sheet_name='Ανάλυση_Μετρήσεων', index=False)
        logger.info(f"Excel Στατιστικών: {OUTPUT_EXCEL_STATS}")
    except Exception as e:
        logger.error(f"Αποτυχία δημιουργίας Excel Στατιστικών: {e}")

# =============================================================================
# ENTRY POINT
# =============================================================================

if __name__ == '__main__':
    run_batch()
