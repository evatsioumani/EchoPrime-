# =============================================================================
# THRESHOLD SELECTION
# =============================================================================

def select_threshold(y_true, y_pred_proba, strategy, target=None):
    """
    Pick an operating point on the ROC curve according to the requested
    strategy. Returns (threshold, achieved_sens, achieved_spec).

    Strategies
    ----------
    youden : argmax(TPR − FPR). Standard balanced operating point.
    min_sensitivity : lowest threshold with TPR ≥ target. Among ties on TPR,
                      we keep the highest threshold (= best specificity)
                      because sklearn's roc_curve already returns thresholds
                      in decreasing order.
    min_specificity : highest threshold with (1 − FPR) ≥ target. Among ties,
                      we keep the lowest threshold (= best sensitivity).

    If the constraint cannot be satisfied (e.g. dataset is too small or the
    classifier never reaches that sensitivity), we fall back to the threshold
    that gets closest to the target and flag it in the returned spec/sens.
    """
    fpr, tpr, thr = roc_curve(y_true, y_pred_proba)
    # sklearn prepends a +inf threshold so the curve starts at (0, 0).
    # That sentinel is not a real operating point — drop it.
    valid = np.isfinite(thr)
    fpr, tpr, thr = fpr[valid], tpr[valid], thr[valid]

    if len(thr) == 0:
        return 0.5, np.nan, np.nan

    spec = 1.0 - fpr  # specificity at each operating point

    if strategy == 'youden':
        j = tpr - fpr
        idx = int(np.argmax(j))
        return float(thr[idx]), float(tpr[idx]), float(spec[idx])

    if strategy == 'min_sensitivity':
        # We want sens ≥ target while keeping spec as high as possible.
        # roc_curve returns thresholds in *decreasing* order, so as we move
        # forward in the array TPR is non-decreasing. The first index that
        # meets the target is also the one with the highest threshold (best
        # specificity) among those that meet it.
        eligible = np.where(tpr >= target)[0]
        if len(eligible) == 0:
            idx = int(np.argmax(tpr))  # best we can do
        else:
            idx = int(eligible[0])
        return float(thr[idx]), float(tpr[idx]), float(spec[idx])

    if strategy == 'min_specificity':
        # We want spec ≥ target while keeping sens as high as possible.
        # spec is non-increasing along the array (since FPR is non-decreasing),
        # so the *last* index that satisfies the constraint maximizes TPR.
        eligible = np.where(spec >= target)[0]
        if len(eligible) == 0:
            idx = int(np.argmax(spec))
        else:
            idx = int(eligible[-1])
        return float(thr[idx]), float(tpr[idx]), float(spec[idx])

    raise ValueError(f"Unknown threshold strategy: {strategy}")


# =============================================================================
# BOOTSTRAPPING ENGINE
# =============================================================================

def bootstrap_metric(y_true, y_pred, metric_fn, n_bootstraps, seed, needs_both_classes=True):
    """Generic bootstrapper. See v5 docstring; behavior unchanged."""
    rng = np.random.RandomState(seed)
    point_estimate = metric_fn(y_true, y_pred)

    bootstrapped_scores = []
    for _ in range(n_bootstraps):
        indices = rng.randint(0, len(y_true), len(y_true))
        y_t = y_true[indices]
        y_p = y_pred[indices]

        if needs_both_classes and len(np.unique(y_t)) < 2:
            continue

        try:
            score = metric_fn(y_t, y_p)
            bootstrapped_scores.append(score)
        except (ValueError, ZeroDivisionError):
            continue

    if len(bootstrapped_scores) == 0:
        return point_estimate, np.nan, np.nan

    sorted_scores = np.sort(bootstrapped_scores)
    ci_lower = np.percentile(sorted_scores, 2.5)
    ci_upper = np.percentile(sorted_scores, 97.5)

    return point_estimate, ci_lower, ci_upper


# =============================================================================
# METRIC FUNCTIONS
# =============================================================================

def _sensitivity(y_true, y_pred_binary):
    tp = np.sum((y_pred_binary == 1) & (y_true == 1))
    fn = np.sum((y_pred_binary == 0) & (y_true == 1))
    denom = tp + fn
    return tp / denom if denom > 0 else np.nan

def _specificity(y_true, y_pred_binary):
    tn = np.sum((y_pred_binary == 0) & (y_true == 0))
    fp = np.sum((y_pred_binary == 1) & (y_true == 0))
    denom = tn + fp
    return tn / denom if denom > 0 else np.nan

def _ppv(y_true, y_pred_binary):
    tp = np.sum((y_pred_binary == 1) & (y_true == 1))
    fp = np.sum((y_pred_binary == 1) & (y_true == 0))
    denom = tp + fp
    return tp / denom if denom > 0 else np.nan

def _npv(y_true, y_pred_binary):
    tn = np.sum((y_pred_binary == 0) & (y_true == 0))
    fn = np.sum((y_pred_binary == 0) & (y_true == 1))
    denom = tn + fn
    return tn / denom if denom > 0 else np.nan


# =============================================================================
# PLOTTING FUNCTIONS
# =============================================================================

def plot_roc_curve_with_operating_points(y_true, y_pred, auroc, ci_lower, ci_upper,
                                         feature_name, operating_points, save_path):
    """ROC curve with every trial's operating point overlaid."""
    fpr, tpr, _ = roc_curve(y_true, y_pred)

    fig, ax = plt.subplots(1, 1, figsize=(8, 7))
    ax.plot(fpr, tpr, color='#2563EB', lw=2.0,
            label=f'AUROC = {auroc:.3f} ({ci_lower:.3f}–{ci_upper:.3f})')
    ax.plot([0, 1], [0, 1], color='#9CA3AF', lw=1.0, linestyle='--', label='Random Classifier')
    ax.fill_between(fpr, tpr, alpha=0.08, color='#2563EB')

    # Mark each trial's operating point: x = 1 − spec, y = sens.
    marker_styles = ['o', 's', 'D', '^', 'v']
    colors = ['#DC2626', '#F59E0B', '#10B981', '#7C3AED', '#0EA5E9']
    for i, (label, sens, spec, thr) in enumerate(operating_points):
        if np.isnan(sens) or np.isnan(spec):
            continue
        ax.scatter(1 - spec, sens, s=110, marker=marker_styles[i % 5],
                   color=colors[i % 5], edgecolor='black', linewidth=1.2, zorder=5,
                   label=f'{label} | thr={thr:.3f} | sens={sens:.3f}, spec={spec:.3f}')

    ax.set_xlabel('False Positive Rate (1 − Specificity)', fontsize=12)
    ax.set_ylabel('True Positive Rate (Sensitivity)', fontsize=12)
    ax.set_title(f'ROC Curve — {feature_name}', fontsize=13, fontweight='bold')
    ax.legend(loc='lower right', fontsize=8, framealpha=0.9)
    ax.set_xlim([-0.01, 1.01])
    ax.set_ylim([-0.01, 1.01])
    ax.set_aspect('equal')
    ax.grid(True, alpha=0.3)

    fig.tight_layout()
    fig.savefig(save_path, dpi=200, bbox_inches='tight')
    plt.close(fig)


def plot_pr_curve(y_true, y_pred, auprc, ci_lower, ci_upper, feature_name, prevalence, save_path):
    precision, recall, _ = precision_recall_curve(y_true, y_pred)

    fig, ax = plt.subplots(1, 1, figsize=(7, 6))
    ax.plot(recall, precision, color='#DC2626', lw=2.0,
            label=f'AUPRC = {auprc:.3f} ({ci_lower:.3f}–{ci_upper:.3f})')
    ax.axhline(y=prevalence, color='#9CA3AF', lw=1.0, linestyle='--',
               label=f'Prevalence = {prevalence:.3f}')
    ax.fill_between(recall, precision, alpha=0.08, color='#DC2626')

    ax.set_xlabel('Recall (Sensitivity)', fontsize=12)
    ax.set_ylabel('Precision (PPV)', fontsize=12)
    ax.set_title(f'Precision-Recall Curve — {feature_name}', fontsize=13, fontweight='bold')
    ax.legend(loc='upper right', fontsize=10, framealpha=0.9)
    ax.set_xlim([-0.01, 1.01])
    ax.set_ylim([-0.01, 1.01])
    ax.grid(True, alpha=0.3)

    fig.tight_layout()
    fig.savefig(save_path, dpi=200, bbox_inches='tight')
    plt.close(fig)


def plot_confusion_matrix(cm, feature_name, trial_label, threshold, save_path):
    fig, ax = plt.subplots(1, 1, figsize=(6, 5))
    total = cm.sum()
    cm_pct = cm / total * 100 if total > 0 else cm * 0.0

    annot_labels = np.array([
        [f"{cm[i, j]}\n({cm_pct[i, j]:.1f}%)" for j in range(2)]
        for i in range(2)
    ])

    im = ax.imshow(cm, interpolation='nearest', cmap='Blues')
    for i in range(2):
        for j in range(2):
            text_color = 'white' if cm[i, j] > cm.max() / 2 else 'black'
            ax.text(j, i, annot_labels[i, j], ha='center', va='center',
                    fontsize=13, color=text_color, fontweight='bold')

    ax.set_xticks([0, 1])
    ax.set_yticks([0, 1])
    ax.set_xticklabels(['Negative', 'Positive'], fontsize=11)
    ax.set_yticklabels(['Negative', 'Positive'], fontsize=11)
    ax.set_xlabel('Predicted Label', fontsize=12)
    ax.set_ylabel('True Label', fontsize=12)
    ax.set_title(f'Confusion Matrix — {feature_name}\n{trial_label} (thr = {threshold:.3f})',
                 fontsize=12, fontweight='bold')

    fig.colorbar(im, ax=ax, shrink=0.8)
    fig.tight_layout()
    fig.savefig(save_path, dpi=200, bbox_inches='tight')
    plt.close(fig)


# =============================================================================
# PER-TRIAL EVALUATION
# =============================================================================

def evaluate_at_threshold(y_true, y_pred_proba, threshold,
                          n_bootstraps=N_BOOTSTRAPS, seed=RANDOM_SEED):
    """Compute Sens/Spec/PPV/NPV (with 95% CIs) and the confusion matrix
    for a given operating threshold."""
    y_pred_binary = (y_pred_proba >= threshold).astype(int)

    sens, sens_lo, sens_hi = bootstrap_metric(
        y_true, y_pred_binary, _sensitivity, n_bootstraps, seed, needs_both_classes=False)
    spec, spec_lo, spec_hi = bootstrap_metric(
        y_true, y_pred_binary, _specificity, n_bootstraps, seed, needs_both_classes=False)
    ppv_val, ppv_lo, ppv_hi = bootstrap_metric(
        y_true, y_pred_binary, _ppv, n_bootstraps, seed, needs_both_classes=False)
    npv_val, npv_lo, npv_hi = bootstrap_metric(
        y_true, y_pred_binary, _npv, n_bootstraps, seed, needs_both_classes=False)

    cm = confusion_matrix(y_true, y_pred_binary, labels=[0, 1])
    tn, fp, fn, tp = cm.ravel()

    return {
        'threshold': threshold,
        'sens': sens, 'sens_lo': sens_lo, 'sens_hi': sens_hi,
        'spec': spec, 'spec_lo': spec_lo, 'spec_hi': spec_hi,
        'ppv':  ppv_val, 'ppv_lo':  ppv_lo, 'ppv_hi':  ppv_hi,
        'npv':  npv_val, 'npv_lo':  npv_lo, 'npv_hi':  npv_hi,
        'tp': int(tp), 'fp': int(fp), 'tn': int(tn), 'fn': int(fn),
        'cm': cm,
    }


