# MAIN PIPELINE
# =============================================================================

def run_evaluation():
    print("=" * 72)
    print("  EchoPrime Full Metrics Evaluator v6.0")
    print("  Metrics: AUROC, AUPRC, Sens, Spec, PPV, NPV (across 5 trials)")
    print(f"  Method:  {N_BOOTSTRAPS:,} Bootstrap Iterations | 95% CI")
    print("=" * 72)
    print("  Trials:")
    for _, name, _, _ in TRIALS:
        print(f"    • {name}")
    print("=" * 72)

    # ----- 1. Load Data -----
    print("\n[1/5] Loading data...")
    df_gt = pd.read_csv(GROUND_TRUTH_FILE) if GROUND_TRUTH_FILE.endswith('.csv') else pd.read_excel(GROUND_TRUTH_FILE)
    df_pred = pd.read_csv(PREDICTIONS_FILE) if PREDICTIONS_FILE.endswith('.csv') else pd.read_excel(PREDICTIONS_FILE)
    print(f"  Ground Truth:  {df_gt.shape[0]} rows, {df_gt.shape[1]} columns")
    print(f"  Predictions:   {df_pred.shape[0]} rows, {df_pred.shape[1]} columns")

    # ----- 2. Merge -----
    actual_pred_id = PRED_ID_COLUMN if PRED_ID_COLUMN in df_pred.columns else GT_ID_COLUMN
    df_merged = pd.merge(df_gt, df_pred, left_on=GT_ID_COLUMN, right_on=actual_pred_id, suffixes=('_gt', '_pred'))
    print(f"  Merged:        {len(df_merged)} matched examinations")

    # ----- 3. Apply Exclusions -----
    all_exclude_ids = set()
    
    for excl_file in EXCLUSION_FILES:
        if os.path.exists(excl_file):
            try:
                with open(excl_file, 'r', encoding='utf-8') as f:
                    # Προσθήκη των IDs στο κοινό set
                    all_exclude_ids.update([line.strip() for line in f if line.strip()])
            except Exception as e:
                print(f"  [ERROR] Could not read exclusion file: {e}")
        else:
            print(f"  [INFO] No exclusion file found at: {excl_file}")

    if all_exclude_ids:
        initial_count = len(df_merged)
        df_merged = df_merged[~df_merged[GT_ID_COLUMN].astype(str).isin([str(i) for i in all_exclude_ids])]
        removed = initial_count - len(df_merged)
        print(f"  Excluded:      {removed} examinations (from {len(EXCLUSION_FILES)} exclusion files)")
    else:
        print("  [INFO] No IDs to exclude were found in the provided files.")

    n_samples = len(df_merged)

    # ----- 4. Output directories -----
    os.makedirs(os.path.dirname(OUTPUT_EXCEL), exist_ok=True)
    os.makedirs(OUTPUT_PLOTS_DIR, exist_ok=True)
    roc_dir = os.path.join(OUTPUT_PLOTS_DIR, 'roc_curves')
    pr_dir  = os.path.join(OUTPUT_PLOTS_DIR, 'pr_curves')
    cm_root = os.path.join(OUTPUT_PLOTS_DIR, 'confusion_matrices')
    os.makedirs(roc_dir, exist_ok=True)
    os.makedirs(pr_dir, exist_ok=True)
    # one subfolder per trial for the confusion matrices
    for trial_key, _, _, _ in TRIALS:
        os.makedirs(os.path.join(cm_root, trial_key), exist_ok=True)

    # ----- 5. Evaluate each feature × each trial -----
    print(f"\n[2/5] Computing metrics across {len(TRIALS)} trials × {len(FEATURES)} features...")

    # Per-trial accumulators (one row per feature, per trial)
    per_trial_rows = {trial_key: [] for trial_key, _, _, _ in TRIALS}
    # Threshold log: one row per (feature × trial)
    threshold_rows = []

    for feature in tqdm(FEATURES, desc="Evaluating Features"):
        col_gt = f"{feature}_gt"
        col_pred = f"{feature}_pred"
        display_name = FEATURE_DISPLAY_NAMES.get(feature, feature)

        if col_gt not in df_merged.columns or col_pred not in df_merged.columns:
            print(f"\n  [WARNING] Missing columns for '{feature}'. Skipping.")
            continue

        df_valid = df_merged[[col_gt, col_pred]].dropna()
        y_true = df_valid[col_gt].values.astype(float)
        y_pred_proba = df_valid[col_pred].values.astype(float)

        n_positive = int(y_true.sum())
        n_negative = int(len(y_true) - n_positive)
        n_total = len(y_true)
        prevalence = n_positive / n_total if n_total > 0 else 0.0

        # Single-class guard: AUROC/AUPRC undefined, all trials NaN.
        if len(np.unique(y_true)) < 2:
            print(f"\n  [WARNING] '{feature}' has only 1 class. Filling NaNs across all trials.")
            for trial_key, trial_name, _, _ in TRIALS:
                per_trial_rows[trial_key].append({
                    'Feature': display_name,
                    'AUROC': np.nan, 'AUROC_CI_Lower': np.nan, 'AUROC_CI_Upper': np.nan,
                    'AUPRC': np.nan, 'AUPRC_CI_Lower': np.nan, 'AUPRC_CI_Upper': np.nan,
                    'Threshold': np.nan,
                    'Sensitivity': np.nan, 'Sens_CI_Lower': np.nan, 'Sens_CI_Upper': np.nan,
                    'Specificity': np.nan, 'Spec_CI_Lower': np.nan, 'Spec_CI_Upper': np.nan,
                    'PPV': np.nan, 'PPV_CI_Lower': np.nan, 'PPV_CI_Upper': np.nan,
                    'NPV': np.nan, 'NPV_CI_Lower': np.nan, 'NPV_CI_Upper': np.nan,
                    'TP': 0, 'FP': 0, 'TN': 0, 'FN': 0,
                    'Positive_Samples': n_positive, 'Negative_Samples': n_negative,
                    'Total_Samples': n_total, 'Prevalence': prevalence,
                })
                threshold_rows.append({
                    'Feature': display_name, 'Trial': trial_name,
                    'Threshold': np.nan, 'Achieved_Sensitivity': np.nan,
                    'Achieved_Specificity': np.nan, 'Constraint_Met': False,
                })
            continue

        # ---- Threshold-independent: AUROC / AUPRC, computed once ----
        auroc, auroc_lo, auroc_hi = bootstrap_metric(
            y_true, y_pred_proba, roc_auc_score, N_BOOTSTRAPS, RANDOM_SEED)
        auprc, auprc_lo, auprc_hi = bootstrap_metric(
            y_true, y_pred_proba, average_precision_score, N_BOOTSTRAPS, RANDOM_SEED)

        # ---- One PR curve per feature ----
        plot_pr_curve(y_true, y_pred_proba, auprc, auprc_lo, auprc_hi,
                      display_name, prevalence,
                      os.path.join(pr_dir, f'pr_{feature}.png'))

        # ---- Iterate through the 5 trials ----
        operating_points_for_roc = []  # for the combined ROC plot

        for trial_key, trial_name, strategy, target in TRIALS:
            thr, achieved_sens, achieved_spec = select_threshold(
                y_true, y_pred_proba, strategy, target)

            # Did the constraint actually get met?
            if strategy == 'youden':
                constraint_met = True
            elif strategy == 'min_sensitivity':
                constraint_met = bool(achieved_sens >= target) if not np.isnan(achieved_sens) else False
            elif strategy == 'min_specificity':
                constraint_met = bool(achieved_spec >= target) if not np.isnan(achieved_spec) else False
            else:
                constraint_met = False

            metrics = evaluate_at_threshold(y_true, y_pred_proba, thr)

            # Confusion matrix plot for this (feature, trial)
            plot_confusion_matrix(
                metrics['cm'], display_name, trial_name, thr,
                os.path.join(cm_root, trial_key, f'cm_{feature}.png'))

            operating_points_for_roc.append(
                (trial_name, metrics['sens'], metrics['spec'], thr))

            per_trial_rows[trial_key].append({
                'Feature': display_name,
                'AUROC': round(auroc, 3),
                'AUROC_CI_Lower': round(auroc_lo, 3),
                'AUROC_CI_Upper': round(auroc_hi, 3),
                'AUPRC': round(auprc, 3),
                'AUPRC_CI_Lower': round(auprc_lo, 3),
                'AUPRC_CI_Upper': round(auprc_hi, 3),
                'Threshold': round(thr, 4),
                'Sensitivity': round(metrics['sens'], 3),
                'Sens_CI_Lower': round(metrics['sens_lo'], 3),
                'Sens_CI_Upper': round(metrics['sens_hi'], 3),
                'Specificity': round(metrics['spec'], 3),
                'Spec_CI_Lower': round(metrics['spec_lo'], 3),
                'Spec_CI_Upper': round(metrics['spec_hi'], 3),
                'PPV': round(metrics['ppv'], 3),
                'PPV_CI_Lower': round(metrics['ppv_lo'], 3),
                'PPV_CI_Upper': round(metrics['ppv_hi'], 3),
                'NPV': round(metrics['npv'], 3),
                'NPV_CI_Lower': round(metrics['npv_lo'], 3),
                'NPV_CI_Upper': round(metrics['npv_hi'], 3),
                'TP': metrics['tp'], 'FP': metrics['fp'],
                'TN': metrics['tn'], 'FN': metrics['fn'],
                'Positive_Samples': n_positive, 'Negative_Samples': n_negative,
                'Total_Samples': n_total, 'Prevalence': round(prevalence, 4),
                'Constraint_Met': constraint_met,
            })

            threshold_rows.append({
                'Feature': display_name,
                'Trial': trial_name,
                'Threshold': round(thr, 4),
                'Achieved_Sensitivity': round(metrics['sens'], 4),
                'Achieved_Specificity': round(metrics['spec'], 4),
                'Constraint_Met': constraint_met,
            })

        # ---- Single ROC plot per feature with all 5 operating points marked ----
        plot_roc_curve_with_operating_points(
            y_true, y_pred_proba, auroc, auroc_lo, auroc_hi, display_name,
            operating_points_for_roc,
            os.path.join(roc_dir, f'roc_{feature}.png'))

    # ----- 6. Build per-trial DataFrames -----
    print("\n[3/5] Building results tables...")

    def fmt_ci(row, metric, lo_col, hi_col):
        if pd.isna(row[metric]):
            return "N/A"
        return f"{row[metric]:.3f} ({row[lo_col]:.3f}–{row[hi_col]:.3f})"

    trial_dfs = {}
    for trial_key, trial_name, _, _ in TRIALS:
        df_trial = pd.DataFrame(per_trial_rows[trial_key])
        if df_trial.empty:
            trial_dfs[trial_key] = (trial_name, df_trial)
            continue

        df_trial['AUROC (95% CI)'] = df_trial.apply(
            lambda r: fmt_ci(r, 'AUROC', 'AUROC_CI_Lower', 'AUROC_CI_Upper'), axis=1)
        df_trial['AUPRC (95% CI)'] = df_trial.apply(
            lambda r: fmt_ci(r, 'AUPRC', 'AUPRC_CI_Lower', 'AUPRC_CI_Upper'), axis=1)
        df_trial['Sensitivity (95% CI)'] = df_trial.apply(
            lambda r: fmt_ci(r, 'Sensitivity', 'Sens_CI_Lower', 'Sens_CI_Upper'), axis=1)
        df_trial['Specificity (95% CI)'] = df_trial.apply(
            lambda r: fmt_ci(r, 'Specificity', 'Spec_CI_Lower', 'Spec_CI_Upper'), axis=1)
        df_trial['PPV (95% CI)'] = df_trial.apply(
            lambda r: fmt_ci(r, 'PPV', 'PPV_CI_Lower', 'PPV_CI_Upper'), axis=1)
        df_trial['NPV (95% CI)'] = df_trial.apply(
            lambda r: fmt_ci(r, 'NPV', 'NPV_CI_Lower', 'NPV_CI_Upper'), axis=1)
        trial_dfs[trial_key] = (trial_name, df_trial)

    df_thresholds = pd.DataFrame(threshold_rows)

    # ----- 7. Save to Excel -----
    print("\n[4/5] Saving results to Excel...")

    summary_cols = [
        'Feature', 'AUROC (95% CI)', 'AUPRC (95% CI)',
        'Threshold',
        'Sensitivity (95% CI)', 'Specificity (95% CI)',
        'PPV (95% CI)', 'NPV (95% CI)',
        'Positive_Samples', 'Negative_Samples', 'Total_Samples', 'Prevalence',
        'Constraint_Met',
    ]

    # Excel sheet names: max 31 chars, no special chars.
    def safe_sheet_name(name, suffix=''):
        base = name.replace('—', '-').replace('≥', '>=')
        full = (base + suffix)[:31]
        return full

    with pd.ExcelWriter(OUTPUT_EXCEL, engine='openpyxl') as writer:
        # One Summary sheet + one Full sheet per trial
        for trial_key, (trial_name, df_trial) in trial_dfs.items():
            if df_trial.empty:
                continue
            cols_present = [c for c in summary_cols if c in df_trial.columns]
            df_trial[cols_present].to_excel(
                writer, sheet_name=safe_sheet_name(trial_name, ' Sum'), index=False)
            df_trial.to_excel(
                writer, sheet_name=safe_sheet_name(trial_name, ' Full'), index=False)

        # Cross-trial threshold log
        df_thresholds.to_excel(writer, sheet_name='Thresholds', index=False)

        # Cross-trial comparison: one row per feature, sens/spec across trials
        comparison = None
        for trial_key, (trial_name, df_trial) in trial_dfs.items():
            if df_trial.empty:
                continue
            sub = df_trial[['Feature', 'Threshold', 'Sensitivity', 'Specificity', 'PPV', 'NPV']].copy()
            sub.columns = ['Feature',
                           f'{trial_name} | thr',
                           f'{trial_name} | Sens',
                           f'{trial_name} | Spec',
                           f'{trial_name} | PPV',
                           f'{trial_name} | NPV']
            comparison = sub if comparison is None else comparison.merge(sub, on='Feature', how='outer')
        if comparison is not None:
            comparison.to_excel(writer, sheet_name='Cross_Trial_Comparison', index=False)

    # ----- 8. Console Summary -----
    print("\n[5/5] Evaluation Complete!")
    print("=" * 110)
    for trial_key, (trial_name, df_trial) in trial_dfs.items():
        if df_trial.empty:
            continue
        print(f"\n>>> {trial_name}")
        print("-" * 110)
        print(f"{'Feature':<30} | {'Threshold':>9} | {'Sens':>6} | {'Spec':>6} | {'PPV':>6} | {'NPV':>6} | {'Met':>5}")
        print("-" * 110)
        for _, row in df_trial.iterrows():
            thr_str  = f"{row['Threshold']:.3f}"   if pd.notna(row['Threshold'])   else "N/A"
            sens_str = f"{row['Sensitivity']:.3f}" if pd.notna(row['Sensitivity']) else "N/A"
            spec_str = f"{row['Specificity']:.3f}" if pd.notna(row['Specificity']) else "N/A"
            ppv_str  = f"{row['PPV']:.3f}"         if pd.notna(row['PPV'])         else "N/A"
            npv_str  = f"{row['NPV']:.3f}"         if pd.notna(row['NPV'])         else "N/A"
            met_str  = "Y" if row.get('Constraint_Met', False) else "N"
            print(f"{row['Feature']:<30} | {thr_str:>9} | {sens_str:>6} | {spec_str:>6} | {ppv_str:>6} | {npv_str:>6} | {met_str:>5}")

    print("\n" + "=" * 110)
    print(f"  Excel:  {OUTPUT_EXCEL}")
    print(f"  Plots:  {OUTPUT_PLOTS_DIR}/")
    print(f"          ├── roc_curves/                 ({len(FEATURES)} ROC curves, all 5 op-points marked)")
    print(f"          ├── pr_curves/                  ({len(FEATURES)} PR curves)")
    print(f"          └── confusion_matrices/")
    for trial_key, trial_name, _, _ in TRIALS:
        print(f"              └── {trial_key}/  ({len(FEATURES)} matrices — {trial_name})")
    print(f"\n  Bootstrap iterations: {N_BOOTSTRAPS:,}")
    print(f"  Random seed:          {RANDOM_SEED}")


if __name__ == '__main__':
    run_evaluation()
